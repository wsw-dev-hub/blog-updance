					'B-ZTXMN2cT4', '8qyTs9BjYpk', 'xGuVr_QuoFc'];
					
	/* [ TEXAS WALK - SHAMROCK - HEEL TOE - 
		BUTTERFLY - GABBAGE PATH - ROPE ] */	
		
					//X6nBMR4Xz70   NuGPbfLRw5g

	$('.progress-bar').click(function(){
